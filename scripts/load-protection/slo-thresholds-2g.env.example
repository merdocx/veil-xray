# Пороги SLO для VPS ~2 GiB RAM / 2 vCPU (типичный малый узел)
# Установка: scripts/ops/apply-slo-profile.sh 2g

LOAD1_WARN=1.0
LOAD1_CRIT=3.0

# MemAvailable: warn ~750 MiB, crit ~500 MiB
MEM_AVAIL_WARN_KB=768000
MEM_AVAIL_CRIT_KB=512000

XRAY_RSS_WARN_KB=524288
XRAY_RSS_CRIT_KB=786432

LISTEN_PORT=443
EST_TCP_WARN=1500
EST_TCP_CRIT=3000

FIN_WAIT_WARN=400
FIN_WAIT_CRIT=700
FIN_WAIT_RATIO_WARN=150
FIN_WAIT_RATIO_CRIT=250

TCP_RESTART_FIN_WAIT_CRIT=700
