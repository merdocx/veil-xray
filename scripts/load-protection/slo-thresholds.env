# Пороги SLO (пересмотр 2026-05-26, апгрейд 2 vCPU / 4 GiB, ~101 пользователь)
# check-slo.sh: load_per_cpu = load1 / nproc

LOAD1_WARN=1.0
LOAD1_CRIT=3.0

# MemAvailable в KiB (warn ~1.5 GiB, crit ~1 GiB при 4 GiB RAM)
MEM_AVAIL_WARN_KB=1536000
MEM_AVAIL_CRIT_KB=1048576

# RSS xray (MemoryMax на проде 1G)
XRAY_RSS_WARN_KB=524288
XRAY_RSS_CRIT_KB=786432

# TCP established на порту VPN
LISTEN_PORT=443
EST_TCP_WARN=2500
EST_TCP_CRIT=4000

# FIN-WAIT на :443
FIN_WAIT_WARN=1200
FIN_WAIT_CRIT=2500
FIN_WAIT_RATIO_WARN=150
FIN_WAIT_RATIO_CRIT=250
