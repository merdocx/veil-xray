# Пороги SLO (пересмотр 2026-05-26, ~101 пользователь, baseline /var/log/veil-baseline.log)
# N_cpu=1: load1 совпадает с load1/N_cpu

LOAD1_WARN=0.5
LOAD1_CRIT=1.5

# MemAvailable в KiB (warn ~700 MiB, crit ~500 MiB)
MEM_AVAIL_WARN_KB=716800
MEM_AVAIL_CRIT_KB=512000

# RSS xray в KiB (p50 ~146 MiB, p95 ~183 MiB, max ~246 MiB в выборке)
XRAY_RSS_WARN_KB=204800
XRAY_RSS_CRIT_KB=286720

# TCP established на порту VPN (p50 ~895, p95 ~1400, max ~2708)
LISTEN_PORT=443
EST_TCP_WARN=1500
EST_TCP_CRIT=2200
