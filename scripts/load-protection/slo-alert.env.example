# Скопировать на сервер: /etc/veil-slo-alert.env (chmod 600)
# Подключается из alert-slo-crit.sh

# Повтор алерта при продолжающемся crit (минуты)
# SLO_ALERT_REPEAT_MIN=30

# Telegram/Slack/Discord incoming webhook (опционально)
# SLO_ALERT_WEBHOOK_URL=https://example.com/hook

# Email через local mail (опционально, нужен mailx)
# SLO_ALERT_EMAIL=ops@example.com
