# API Settings
API_SECRET_KEY=change-me-in-production-use-strong-random-key
# Только loopback при схеме Nginx → прокси; для локальной отладки без Nginx можно 0.0.0.0
API_HOST=127.0.0.1
API_PORT=8000

# IP с доступом к API (через запятую). Обязательно админ-сервера + 127.0.0.1
API_ALLOWED_IPS=127.0.0.1,<admin-ip-1>,<admin-ip-2>

# Swagger/OpenAPI (в проде оставьте false)
API_ENABLE_DOCS=false

# CORS: оставьте пустым для server-to-server; или список origin через запятую
API_CORS_ORIGINS=

# Egress (исходящий трафик клиентов) настраивается в /usr/local/etc/xray/config.json,
# не в этом файле. Релей — любой сервер: direct / SOCKS / WireGuard.
# См. docs/operations/egress-modes.md

# Database
DATABASE_URL=sqlite:///./database/veil_xray.db

# Xray API Settings
XRAY_API_HOST=127.0.0.1
XRAY_API_PORT=10085
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json

# Reality Settings (Universal parameters)
REALITY_SERVER_NAME=your-domain.example
# SNI/dest должны отвечать с VPS: curl -sS --max-time 5 https://www.cloudflare.com
REALITY_SNI=cloudflare.com
REALITY_FINGERPRINT=chrome
REALITY_DEST=www.cloudflare.com:443
REALITY_PORT=443
REALITY_ALT_PORT_TCP=446
REALITY_XHTTP_PORT=8445
TROJAN_REALITY_PORT=2085
REALITY_XHTTP_PATH=/a7f9d2c8

# Reality Keys (generate using scripts/init_reality_keys.py)
REALITY_PUBLIC_KEY=
REALITY_PRIVATE_KEY=

# Общий short_id для всех пользователей (8 hex-символов)
REALITY_COMMON_SHORT_ID=7bb45050
REALITY_FLOW=xtls-rprx-vision

# Второй REALITY-профиль (SNI-B), опционально — сгенерировать: python3 scripts/init_reality_keys.py --suffix B
REALITY_SNI_B=cloudflare.com
REALITY_DEST_B=www.cloudflare.com:443
REALITY_PORT_SNI_B=447
REALITY_PUBLIC_KEY_B=
REALITY_PRIVATE_KEY_B=
REALITY_COMMON_SHORT_ID_B=
XRAY_VLESS_REALITY_SNI_B_INBOUND_TAG=vless-reality-sni-b

# Domain / отображение в ссылках (или публичный IP: <VPN_PUBLIC_IP>)
DOMAIN=your-domain.example

# Подписка (по умолчанию profiles=auto):
#   /api/keys/{id}/subscription?profiles=auto&format=base64     — несколько ссылок, клиент выбирает по ping
#   /api/keys/{id}/subscription?profiles=auto&format=singbox_b64 — Happ: sing-box + urltest автовыбор

# Фоновая синхронизация трафика Xray → SQLite (батчами, без блокировки API)
ENABLE_BACKGROUND_TRAFFIC_SYNC=true
BACKGROUND_TRAFFIC_SYNC_INTERVAL_S=600
BACKGROUND_TRAFFIC_SYNC_BATCH_SIZE=50

# Кэш статистики трафика в API (секунды; prod: 3600 = 1 ч)
TRAFFIC_CACHE_TTL_S=3600

# Логирование (в тестах pytest подставляет отдельный файл через LOG_FILE)
LOG_FILE=./logs/veil_xray_api.log
LOG_LEVEL=INFO

